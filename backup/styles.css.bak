* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  background: #000;
  color: white;
  font-family: 'Montserrat', sans-serif;
  overflow-x: hidden;
}

.top-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  width: 100%;
  z-index: 1002;
  background: rgba(0, 0, 0, 0.88);
  border-bottom: 1px solid rgba(215,255,63,0.12);
  backdrop-filter: blur(10px);
  transition: transform 0.25s ease, opacity 0.25s ease;
  transform: translateY(0);
}

.top-bar.hidden {
  transform: translateY(-100%);
  opacity: 0;
}

.top-bar-inner {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 30px;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
}

.top-bar-inner p {
  color: #f5f5f5;
  letter-spacing: 1px;
  text-transform: uppercase;
  font-size: 0.9rem;
  font-weight: 700;
}

.mobile-menu-toggle {
  display: none;
  border: 1px solid rgba(255,255,255,0.12);
  background: transparent;
  color: #d7ff3f;
  width: 46px;
  height: 46px;
  border-radius: 999px;
  font-size: 1.2rem;
  cursor: pointer;
}

.menu-backdrop {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.55);
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
  z-index: 998;
}

.menu-backdrop.active {
  opacity: 1;
  visibility: visible;
}

body.menu-open {
  overflow: hidden;
}

.sidebar-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20px;
}

.sidebar-close {
  display: none;
  background: transparent;
  border: none;
  color: #d7ff3f;
  font-size: 2rem;
  line-height: 1;
  cursor: pointer;
}

.sidebar {
  transition: transform 0.3s ease, opacity 0.3s ease;
}

.sidebar.open {
  transform: translateX(0);
  opacity: 1;
}


.layout {
  display: flex;
  min-height: 100vh;
  padding-top: 70px;
}

.content-wrapper {
  margin-left: 190px;
  width: calc(100% - 190px);
}

@media(max-width: 1100px) {
  .content-wrapper {
    margin-left: 0;
    width: auto;
  }
}

.sidebar {
  width: 190px;
  background: linear-gradient(180deg, #181818 0%, #101010 100%);
  border-right: 1px solid rgba(255,255,255,0.08);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 35px 35px 60px;
  position: fixed;
  top: 0;
  left: 0;
  bottom: 0;
  /* allow the sidebar to scroll if content is taller than viewport */
  height: auto;
  overflow-y: auto;
}

.logo {
  font-size: 42px;
  font-weight: 900;
  color: #d7ff3f;
}
