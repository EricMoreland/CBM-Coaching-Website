{
  "name": "coaching-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "esbuild src/js/main.js --bundle --sourcemap --outdir=dist/js --watch",
    "build": "esbuild src/js/main.js --bundle --minify --outdir=dist/js && npx cpy \"src/*.html\" dist/ && npx cpy \"src/css/**/*\" dist/css",
    "serve": "serve dist -p 5000",
    "lint": "eslint src/js --ext .js",
    "format": "prettier --write \"src/**/*.{js,css,html}\""
  },
  "devDependencies": {
    "esbuild": "^0.18.0",
    "serve": "^14.0.1",
    "eslint": "^8.0.0",
    "prettier": "^2.0.0",
    "stylelint": "^17.0.0",
    "stylelint-config-standard": "^40.0.0",
    "cpy-cli": "^3.0.0"
  }
}
